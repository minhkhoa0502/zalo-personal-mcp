# Path to the persisted Zalo session file (created after QR login).
# Keep this OUTSIDE the repo. Never commit the real file.
ZALO_SESSION_PATH=./.zalo/session.json

# Comma-separated allowlist of Zalo hosts the server is permitted to reach.
# Enforced by the sandbox/egress layer, documented here for reference.
# Derived from the zca-js v2.1.2 audit (docs/audit/zca-js-2.1.2.md):
# static hosts are all under *.zalo.me; dynamic API/WS hosts come from Zalo's
# login response (zpw_service_map / zpw_ws) and are also *.zalo.me; media/CDN
# use *.zadn.vn. With checkUpdate=false there is NO non-Zalo egress.
ZALO_EGRESS_ALLOWLIST=.zalo.me,.zadn.vn,.zaloapp.com,.zdn.vn

# Disable zca-js's npm-registry version check — it is the only non-Zalo egress.
# Keeping it false means the egress allowlist can be Zalo-only.
ZALO_CHECK_UPDATE=false

# Forward proxy for all outbound traffic. In the Docker sandbox this is set
# automatically to the Squid allowlist proxy (see sandbox/). Leave unset to run
# outside the sandbox (direct connections).
# HTTPS_PROXY=http://egress-proxy:3128

# Where the background daemon appends captured messages (read by
# zalo_recent_messages). Defaults next to the session file.
ZALO_MESSAGE_LOG=./.zalo/messages.jsonl

# Whether the listener/daemon also captures YOUR OWN messages. Off by default
# (you usually want messages from others). Set true to log outbound too.
ZALO_SELF_LISTEN=false

# Base Docker image for the build. Defaults to public node:24-alpine so the repo
# builds for anyone. Override to a private mirror/registry if you use one:
# NODE_IMAGE=reg.mini.dev/node:v24.18.0
