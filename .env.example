# Path to the persisted Zalo session file (created after QR login).
# Keep this OUTSIDE the repo. Never commit the real file.
ZALO_SESSION_PATH=./.zalo/session.json

# Comma-separated allowlist of Zalo hosts the server is permitted to reach.
# Enforced by the sandbox/egress layer, documented here for reference.
ZALO_EGRESS_ALLOWLIST=zalo.me,.zalo.me,.zadn.vn,.zaloapp.com
