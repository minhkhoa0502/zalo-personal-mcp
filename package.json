{
  "name": "zalo-personal-mcp",
  "version": "0.0.1",
  "description": "MCP server for automating a personal Zalo account (via zca-js)",
  "type": "module",
  "bin": {
    "zalo-personal-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "audit:deps": "npm audit --omit=dev",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "zalo",
    "claude"
  ],
  "author": "Khoa Tran",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "zca-js": "2.1.2"
  },
  "devDependencies": {
    "@types/node": "26.1.0",
    "typescript": "6.0.3"
  }
}
